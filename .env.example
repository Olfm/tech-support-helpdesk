# Скопируйте этот файл в .env и при необходимости поменяйте значения.
# .env в репозиторий не коммитится (см. .gitignore).

# Секретный ключ Django. Для локальной разработки можно оставить как есть,
# для боевого развёртывания обязательно сгенерируйте новый.
DJANGO_SECRET_KEY=dev-secret-key-change-me

# Режим отладки: True для разработки, False для прода.
DJANGO_DEBUG=True

# Список разрешённых хостов через запятую.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Движок БД: sqlite (по умолчанию) или mysql.
DB_ENGINE=sqlite

# Параметры подключения для MySQL (используются только при DB_ENGINE=mysql).
DB_NAME=tech_support
DB_USER=tech_support
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=3306
